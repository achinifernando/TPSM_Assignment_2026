mark_difference <- function(score1,score2){
# check which score is the largest
if(score1> score2){
difference <- score1 - score2
cat("First score is larger\n")
}else if{
mark_difference <- function(score1,score2){
# check which score is the largest
if(score1> score2){
difference <- score1 - score2
cat("First score is larger\n")
}else if{
mark_difference <- function(score1,score2){
# check which score is the largest
if(score1 > score2){
difference <- score1 - score2
cat("First score is larger\n")
}else if(score2 > score1){
difference <- score2 - score1
cat("Second score is larger\n")
}else{
diference<- 0
cat("Both scores are equal\n")
}
return (abs(difference))
}
