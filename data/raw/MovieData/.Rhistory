quaradic_roots<-function(a,b,c){
D<- b^2 -4*a*c
if(D>0){
root1<-(-b+sqrt(D))/(2*a)
root2<-(-b-sqrt(D))/(2*a)
}else if(D==0){
root<--b/(2*a)
}else{
print("no roots")
}
}
quaradic_roots(2,3,5)
