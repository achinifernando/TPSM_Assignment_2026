#Create a function that computes the perimeter of a rectangle by calling another function to calculate its area. The perimeter function should take the length and width as inputs.
#nested functions
calculate_area = function(l,w){
return(l*w)
}
calculate_perimeter = function(l,w){
area = calculate_area(l,w)
return(2*(l+w))
}
perimeter_result = calculate_perimeter(5,3)
print(perimeter_result)
#Create a function that computes the perimeter of a rectangle by calling another function to calculate its area. The perimeter function should take the length and width as inputs.
#nested functions
calculate_area = function(l,w){
return(l*w)
}
calculate_perimeter = function(l,w){
area = calculate_area(l,w)
print(area)
return(2*(l+w))
}
perimeter_result = calculate_perimeter(5,3)
print(perimeter_result)
